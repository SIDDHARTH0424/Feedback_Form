<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-current.dtd">
<suite name="Feedback Portal Test Suite" verbose="2" parallel="false">

    <test name="Student Feedback Form Tests" preserve-order="true">
        <classes>
            <class name="com.feedback.test.FeedbackFormTest">
                <methods>
                    <include name="testPageTitle"/>
                    <include name="testEmptyFormSubmission"/>
                    <include name="testInvalidEmail"/>
                    <include name="testInvalidMobileNumber"/>
                    <include name="testMissingDepartment"/>
                    <include name="testShortFeedback"/>
                    <include name="testValidFormSubmission"/>
                    <include name="testResetButton"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
